// ============================================================================
// Vista Neotech CMS - Prisma Schema
// Type-safe database access layer
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ContentStatus {
  draft
  published
  archived
  trash
}

enum UserRole {
  super_admin
  admin
  editor
  author
  contributor
}

enum UserStatus {
  active
  inactive
  suspended
}

enum MediaOptimizationStatus {
  pending
  processing
  completed
  failed
}

enum RedirectType {
  PERMANENT_301
  TEMPORARY_302
}

// ============================================================================
// MODELS
// ============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String   @map("password_hash")
  firstName    String?  @map("first_name")
  lastName     String?  @map("last_name")
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(editor)
  status       UserStatus @default(active)
  wordpressId  String?  @map("wordpress_id")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  pages        Page[]
  posts        Post[]
  media        Media[]
  sessions     UserSession[]
  revisions    PageRevision[]
  postRevisions PostRevision[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

model Page {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         String
  content       String?
  excerpt        String?
  status        ContentStatus @default(published)
  contentType   String        @default("page") @map("content_type")
  
  // WordPress Migration
  wordpressId   String?       @map("wordpress_id")
  wordpressUrl  String?       @map("wordpress_url")
  
  // SEO
  metaTitle     String?       @map("meta_title")
  metaDescription String?     @map("meta_description")
  focusKeyword  String?       @map("focus_keyword")
  canonicalUrl  String?       @map("canonical_url")
  
  // Open Graph
  ogTitle       String?       @map("og_title")
  ogDescription String?       @map("og_description")
  ogImage       String?       @map("og_image")
  ogType        String?       @default("website") @map("og_type")
  
  // Twitter
  twitterCard   String?       @default("summary_large_image") @map("twitter_card")
  twitterTitle  String?       @map("twitter_title")
  twitterDescription String?  @map("twitter_description")
  twitterImage  String?       @map("twitter_image")
  
  // Schema
  schemaMarkup  Json?         @map("schema_markup")
  
  // Structure
  template      String?       @default("default")
  featuredImageId String?      @map("featured_image_id")
  menuOrder     Int           @default(0) @map("menu_order")
  parentId      String?       @map("parent_id")
  
  // Metadata
  authorId      String?       @map("author_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  publishedAt   DateTime?     @map("published_at")
  version       Int           @default(1)
  
  // Custom Fields
  customFields  Json          @default("{}") @map("custom_fields")
  
  // Relations
  author        User?         @relation(fields: [authorId], references: [id])
  parent        Page?         @relation("PageHierarchy", fields: [parentId], references: [id])
  children      Page[]         @relation("PageHierarchy")
  featuredImage Media?         @relation("PageFeaturedImage", fields: [featuredImageId], references: [id])
  contentBlocks PageContentBlock[]
  menuItems     MenuItem[]
  revisions     PageRevision[]

  @@index([slug])
  @@index([status])
  @@index([contentType])
  @@index([parentId])
  @@index([publishedAt])
  @@map("pages")
}

model Post {
  id            String        @id @default(uuid())
  slug          String        @unique
  title         String
  content       String?
  excerpt        String?
  status        ContentStatus @default(draft)
  contentType   String        @default("post") @map("content_type")
  
  // WordPress Migration
  wordpressId   String?       @map("wordpress_id")
  wordpressUrl  String?       @map("wordpress_url")
  
  // SEO
  metaTitle     String?       @map("meta_title")
  metaDescription String?     @map("meta_description")
  focusKeyword  String?       @map("focus_keyword")
  canonicalUrl  String?       @map("canonical_url")
  
  // Open Graph
  ogTitle       String?       @map("og_title")
  ogDescription String?       @map("og_description")
  ogImage       String?       @map("og_image")
  ogType        String?       @default("article") @map("og_type")
  
  // Twitter
  twitterCard   String?       @default("summary_large_image") @map("twitter_card")
  twitterTitle  String?       @map("twitter_title")
  twitterDescription String?  @map("twitter_description")
  twitterImage  String?       @map("twitter_image")
  
  // Schema
  schemaMarkup  Json?         @map("schema_markup")
  
  // Featured
  featuredImageId String?     @map("featured_image_id")
  
  // Author & Dates
  authorId      String?       @map("author_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  publishedAt   DateTime?     @map("published_at")
  version       Int           @default(1)
  
  // Custom Fields
  customFields  Json          @default("{}") @map("custom_fields")
  
  // Relations
  author        User?         @relation(fields: [authorId], references: [id])
  featuredImage Media?         @relation("PostFeaturedImage", fields: [featuredImageId], references: [id])
  categories    PostCategory[]
  tags          PostTag[]
  contentBlocks PageContentBlock[]
  menuItems     MenuItem[]
  revisions     PostRevision[]

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
  @@index([authorId])
  @@map("posts")
}

model Category {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String?
  parentId      String?  @map("parent_id")
  menuOrder     Int      @default(0) @map("menu_order")
  metaTitle     String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  wordpressId   String?  @map("wordpress_id")
  wordpressSlug String?  @map("wordpress_slug")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  parent        Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[] @relation("CategoryHierarchy")
  posts         PostCategory[]

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Tag {
  id            String   @id @default(uuid())
  slug          String   @unique
  name          String
  description   String?
  wordpressId   String?  @map("wordpress_id")
  wordpressSlug String?  @map("wordpress_slug")
  createdAt     DateTime @default(now()) @map("created_at")

  posts         PostTag[]

  @@index([slug])
  @@map("tags")
}

model PostCategory {
  postId     String @map("post_id")
  categoryId String @map("category_id")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([postId])
  @@index([categoryId])
  @@map("post_categories")
}

model PostTag {
  postId String @map("post_id")
  tagId  String @map("tag_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([postId])
  @@index([tagId])
  @@map("post_tags")
}

model Media {
  id                String                  @id @default(uuid())
  filename          String
  originalFilename  String?                 @map("original_filename")
  mimeType          String                  @map("mime_type")
  fileSize          BigInt                  @map("file_size")
  filePath          String                  @map("file_path")
  fileUrl           String                  @map("file_url")
  
  // Image
  width             Int?
  height            Int?
  altText           String?                 @map("alt_text")
  caption           String?
  description       String?
  
  // Video
  duration          Int?
  thumbnailPath     String?                 @map("thumbnail_path")
  thumbnailUrl      String?                @map("thumbnail_url")
  
  // Optimization
  optimizedPath     String?                 @map("optimized_path")
  optimizedUrl      String?                 @map("optimized_url")
  optimizationStatus MediaOptimizationStatus @default(pending) @map("optimization_status")
  optimizationMetadata Json?                @map("optimization_metadata")
  variants          Json                   @default("[]")
  
  // Metadata
  uploadedBy        String?                 @map("uploaded_by")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  
  // WordPress
  wordpressId       String?                 @map("wordpress_id")
  wordpressUrl      String?                 @map("wordpress_url")
  
  // Custom Fields
  customFields      Json                    @default("{}") @map("custom_fields")
  
  // Relations
  uploader          User?                   @relation(fields: [uploadedBy], references: [id])
  pageFeaturedImages Page[]                @relation("PageFeaturedImage")
  postFeaturedImages Post[]                 @relation("PostFeaturedImage")
  collectionItems   MediaCollectionItem[]

  @@index([mimeType])
  @@index([uploadedBy])
  @@index([optimizationStatus])
  @@map("media")
}

model MediaCollection {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  type        String   @default("gallery")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       MediaCollectionItem[]

  @@index([slug])
  @@map("media_collections")
}

model MediaCollectionItem {
  collectionId String @map("collection_id")
  mediaId      String @map("media_id")
  orderIndex   Int    @default(0) @map("order_index")
  collection   MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  media        Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([collectionId, mediaId])
  @@map("media_collection_items")
}

model ContentBlock {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  type        String
  content     Json
  settings    Json     @default("{}")
  isReusable  Boolean  @default(true) @map("is_reusable")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  pageBlocks  PageContentBlock[]

  @@index([slug])
  @@index([type])
  @@map("content_blocks")
}

model PageContentBlock {
  id          String   @id @default(uuid())
  pageId      String?  @map("page_id")
  postId      String?  @map("post_id")
  blockId     String?  @map("block_id")
  blockType   String   @map("block_type")
  blockContent Json    @map("block_content")
  orderIndex  Int      @map("order_index")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  page        Page?    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  block       ContentBlock? @relation(fields: [blockId], references: [id], onDelete: SetNull)

  @@index([pageId])
  @@index([postId])
  @@index([orderIndex])
  @@map("page_content_blocks")
}

model Menu {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items     MenuItem[]

  @@index([slug])
  @@index([location])
  @@map("menus")
}

model MenuItem {
  id          String   @id @default(uuid())
  menuId      String   @map("menu_id")
  label       String
  url         String?
  target      String   @default("_self")
  orderIndex  Int      @map("order_index")
  parentId    String?  @map("parent_id")
  pageId      String?  @map("page_id")
  postId      String?  @map("post_id")
  customLink  String?  @map("custom_link")
  icon        String?
  cssClasses  String?  @map("css_classes")
  createdAt   DateTime @default(now()) @map("created_at")

  menu        Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent      MenuItem? @relation("MenuItemHierarchy", fields: [parentId], references: [id])
  children    MenuItem[] @relation("MenuItemHierarchy")
  page        Page?    @relation(fields: [pageId], references: [id])
  post        Post?    @relation(fields: [postId], references: [id])

  @@index([menuId])
  @@index([parentId])
  @@index([orderIndex])
  @@map("menu_items")
}

model Redirect {
  id            String       @id @default(uuid())
  sourceUrl     String       @unique @map("source_url")
  destinationUrl String     @map("destination_url")
  redirectType  Int          @default(301) @map("redirect_type")
  status        String       @default("active")
  hitCount      Int          @default(0) @map("hit_count")
  lastHitAt     DateTime?    @map("last_hit_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([sourceUrl])
  @@index([status])
  @@map("redirects")
}

model SeoSettings {
  id                    String   @id @default(uuid())
  siteName              String?  @map("site_name")
  siteDescription       String?  @map("site_description")
  defaultMetaTitle      String?  @map("default_meta_title")
  defaultMetaDescription String? @map("default_meta_description")
  ogImage               String?  @map("og_image")
  twitterHandle         String?  @map("twitter_handle")
  facebookAppId         String?  @map("facebook_app_id")
  googleAnalyticsId     String?  @map("google_analytics_id")
  googleTagManagerId    String?  @map("google_tag_manager_id")
  schemaMarkup          Json?    @map("schema_markup")
  robotsTxt             String?  @map("robots_txt")
  sitemapSettings       Json     @default("{}") @map("sitemap_settings")
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedBy             String?  @map("updated_by")

  @@map("seo_settings")
}

model SiteSetting {
  key         String   @id
  value       String?
  type        String   @default("string")
  groupName   String?  @map("group_name")
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@index([groupName])
  @@map("site_settings")
}

model PageRevision {
  id            String   @id @default(uuid())
  pageId        String   @map("page_id")
  version       Int
  title         String?
  content       String?
  excerpt        String?
  metaTitle     String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  customFields  Json?    @map("custom_fields")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  creator       User?    @relation(fields: [createdBy], references: [id])

  @@unique([pageId, version])
  @@index([pageId])
  @@map("page_revisions")
}

model PostRevision {
  id            String   @id @default(uuid())
  postId        String   @map("post_id")
  version       Int
  title         String?
  content       String?
  excerpt        String?
  metaTitle     String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  customFields  Json?    @map("custom_fields")
  createdBy     String?  @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  creator       User?    @relation(fields: [createdBy], references: [id])

  @@unique([postId, version])
  @@index([postId])
  @@map("post_revisions")
}
